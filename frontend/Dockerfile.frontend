FROM node:22-alpine AS build

WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .

# Empty VITE_API_BASE_URL → API calls go to the same origin (Caddy proxies /api/*)
ENV VITE_API_BASE_URL=""
RUN npm run build

# ── Serve ────────────────────────────────────────────────────────────────────
FROM caddy:2-alpine

COPY --from=build /app/dist /srv
COPY Caddyfile /etc/caddy/Caddyfile

EXPOSE 80
